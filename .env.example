# ── Supabase ──
# Public keys — bundled with the frontend, safe to expose.
# Get these from your Supabase project dashboard → Settings → API.
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Supabase (server-only) ──
# Service role key bypasses RLS. Use ONLY in Edge Functions, NEVER in the browser.
# Set these in the Supabase dashboard → Edge Functions → Secrets.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── PayFast (server-only) ──
# SA-native payment gateway. Set these in Supabase Edge Function secrets.
# Get credentials from payfast.co.za → Account → Settings → Integration.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=abcdef123456
PAYFAST_PASSPHRASE=your-secure-passphrase
# Set to "true" for test mode (sandbox.payfast.co.za), "false" for live.
PAYFAST_SANDBOX=true

# ── Resend (server-only) ──
# Transactional email API. Get your key from resend.com → API Keys.
# Set in Supabase Edge Function secrets.
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email address that receives new order notifications.
# Set in Supabase Edge Function secrets.
MERCHANT_EMAIL=orders@allthingswater.co.za

# ── Site URL (server-only) ──
# Canonical base URL used for PayFast return/cancel URLs.
# Set in Supabase Edge Function secrets.
PUBLIC_SITE_URL=http://localhost:5180

# ── Sentry (public) ──
# Frontend error monitoring DSN. Safe to bundle.
# If using both frontend + backend Sentry, use separate DSNs.
VITE_SENTRY_DSN=

# ── Admin ──
# The /admin dashboard uses Supabase Auth — there is no admin password env var.
# Create the admin user in Supabase (Authentication → Users), add them to the
# public.admins table (see supabase/migrations/005_admin_auth.sql), and disable
# public sign-ups. The admin-sync Edge Function verifies the user's JWT against
# that allowlist server-side, so no admin secret is ever shipped to the browser.

# ── Analytics ──
# Set to "true" to enable page-view and event tracking (console stubs by default).
VITE_ANALYTICS_ENABLED=false

# Google Analytics 4 measurement ID (only used when a GA4 tracker is wired in).
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Contact Form ──
# Formspree-style endpoint that handles the /contact form submissions.
# Leave empty to log to console (dev mode).
VITE_CONTACT_FORM_ENDPOINT=

# ── Newsletter ──
# Endpoint for newsletter/email subscription form in the footer.
# Leave empty to log to console (dev mode).
VITE_NEWSLETTER_ENDPOINT=

# ── Company Info ──
# Displayed in the footer, structured data, and WhatsApp quick-link.
VITE_WHATSAPP_NUMBER=+27123456789
VITE_COMPANY_EMAIL=info@allthingswater.co.za
VITE_COMPANY_PHONE=+27123456789
VITE_COMPANY_ADDRESS=123 Water St, Johannesburg, 2000
